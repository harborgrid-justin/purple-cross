# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/purple_cross?schema=public"

# Redis Configuration (for caching and BullMQ job queue)
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
# Secrets MUST be at least 32 characters and JWT_REFRESH_SECRET must differ from
# JWT_SECRET. There is NO insecure default: the app fails to boot if these are
# missing or too short. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-generate-a-strong-32+-char-secret-value
JWT_REFRESH_SECRET=change-me-generate-a-different-32+-char-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Field-level encryption key for PHI columns at rest (>=16 chars; a 32-byte AES
# key is derived from it via SHA-256). Required in all environments.
# Generate with: openssl rand -base64 48
FIELD_ENCRYPTION_KEY=change-me-generate-a-strong-field-encryption-key

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Email Configuration (SendGrid, AWS SES, etc.)
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@purplecross.vet
SENDGRID_API_KEY=

# SMS Configuration (Twilio, AWS SNS, etc.)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS Configuration (S3, SES, SNS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Log shipping (optional) - POST structured, PII-redacted logs to an HTTP sink
# (Logstash HTTP input / Vector / Loki / Datadog). Disabled unless ENABLED=true.
LOG_SHIPPING_ENABLED=false
LOG_SHIPPING_HOST=
LOG_SHIPPING_PORT=443
LOG_SHIPPING_PATH=/
LOG_SHIPPING_SSL=true
LOG_SHIPPING_API_KEY=

# Monitoring - Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Distributed tracing - OpenTelemetry (optional). When OTEL_ENABLED=true the API
# and worker export spans (http/express/pg/ioredis auto-instrumentation) over
# OTLP/HTTP to the collector below.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=purple-cross-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Outbound integration resilience - retry attempts per provider call (email/SMS).
# Each attempt is additionally guarded by a per-provider circuit breaker.
INTEGRATION_RETRY_ATTEMPTS=3

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_API_DOCS=true

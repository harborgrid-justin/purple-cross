VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_APP_NAME=Purple Cross
VITE_APP_VERSION=1.0.0

# Observability - Sentry (optional). When VITE_SENTRY_DSN is set, frontend error
# reporting + browser tracing are enabled (PII/PHI scrubbed before send).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
